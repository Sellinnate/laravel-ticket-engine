{
  "title": "Selli Ticketing",
  "url": "https://laravel-ticketing.selli.io",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "collapsible": true,
      "defaultCollapsed": false
    },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": {
        "search": true,
        "themeSwitch": true
      }
    },
    "footer": {
      "style": "minimal",
      "content": "© 2026 Sellinnate S.r.l. — The agnostic ticketing engine for Laravel (MIT).",
      "branding": true
    }
  },
  "theme": {
    "name": "default",
    "appearance": "dark",
    "codeHighlight": true
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Introduction", "path": "/", "icon": "home" },
    {
      "title": "Getting Started",
      "icon": "rocket",
      "collapsible": false,
      "children": [
        { "title": "Installation", "path": "/getting-started/installation", "icon": "download" },
        { "title": "Quick Start", "path": "/getting-started/quick-start", "icon": "zap" },
        { "title": "Core concepts", "path": "/getting-started/concepts", "icon": "lightbulb" }
      ]
    },
    {
      "title": "Concepts",
      "icon": "book-open",
      "children": [
        { "title": "Multi-tenancy", "path": "/concepts/tenancy", "icon": "layers" },
        { "title": "Types & workflow", "path": "/concepts/workflow", "icon": "git-branch" },
        { "title": "SLA & escalation", "path": "/concepts/sla", "icon": "clock" },
        { "title": "Routing & assignment", "path": "/concepts/routing", "icon": "users" },
        { "title": "Collaboration", "path": "/concepts/collaboration", "icon": "message-square" },
        { "title": "CSAT", "path": "/concepts/csat", "icon": "star" },
        { "title": "Automation", "path": "/concepts/automation", "icon": "cpu" },
        { "title": "Notifications", "path": "/concepts/notifications", "icon": "bell" }
      ]
    },
    {
      "title": "Channels",
      "icon": "radio",
      "children": [
        { "title": "REST API", "path": "/channels/rest-api", "icon": "code" },
        { "title": "Email-to-ticket", "path": "/channels/email", "icon": "mail" },
        { "title": "Broadcasting", "path": "/channels/broadcasting", "icon": "wifi" }
      ]
    },
    {
      "title": "Security",
      "icon": "shield",
      "children": [
        { "title": "Authorization", "path": "/security/authorization", "icon": "lock" },
        { "title": "Audit trail", "path": "/security/audit-trail", "icon": "history" },
        { "title": "GDPR & retention", "path": "/security/gdpr", "icon": "user-x" }
      ]
    },
    {
      "title": "Configuration",
      "icon": "cog",
      "children": [
        { "title": "Overview", "path": "/configuration/overview", "icon": "sliders" }
      ]
    },
    {
      "title": "Reference",
      "icon": "book",
      "children": [
        { "title": "Facade & actions", "path": "/reference/facade", "icon": "terminal" },
        { "title": "Events", "path": "/reference/events", "icon": "zap" },
        { "title": "Artisan commands", "path": "/reference/commands", "icon": "command" },
        { "title": "Database schema", "path": "/reference/database-schema", "icon": "database" }
      ]
    },
    { "title": "GitHub", "path": "https://github.com/Sellinnate/laravel-ticket-engine", "icon": "github", "external": true }
  ],
  "plugins": {
    "seo": {
      "defaultDescription": "The agnostic ticketing engine for Laravel: headless, multi-tenant, workflow-driven tickets you attach to your own models — SLA, routing, collaboration, CSAT, automation, REST API, email-to-ticket, broadcasting, authorization, audit trail and GDPR."
    }
  }
}
